{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@shawnderland/ui": ["./packages/ui/src/index.ts"],
      "@shawnderland/ui/*": ["./packages/ui/src/*"],
      "@shawnderland/ai": ["./packages/ai/src/index.ts"],
      "@shawnderland/serling": ["./packages/serling/src/index.ts"],
      "@shawnderland/serling/*": ["./packages/serling/src/*"],
      "@tools/walter": ["./tools/walter/src/index.tsx"],
      "@tools/walter/*": ["./tools/walter/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
