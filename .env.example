# ── Shawnderland OKDO — Environment Variables ──
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will not be committed.

# ── AI Studio (default backend) ──
# Get an API key from https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# ── Vertex AI (optional — unlocks additional models and regions) ──
# Requires a Google Cloud project with Vertex AI API enabled.
# Get an API key from https://console.cloud.google.com/apis/credentials
# NEXT_PUBLIC_VERTEX_PROJECT=your-gcp-project-id
# NEXT_PUBLIC_VERTEX_LOCATION=us-central1
# NEXT_PUBLIC_VERTEX_API_KEY=

# ── Meshy AI (3D model generation) ──
# Get an API key from https://meshy.ai/api
MESHY_API_KEY=

# ── Hitem3D (3D model generation — image-to-3D with portrait models) ──
# Get API keys from https://docs.hitem3d.ai
HITEM3D_ACCESS_KEY=
HITEM3D_SECRET_KEY=

# ── ElevenLabs (TTS, sound effects, voice cloning) ──
# Get an API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
